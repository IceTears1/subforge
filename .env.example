# ========================================
# SubForge 环境配置示例
# 复制此文件为 .env 并按需修改
# ========================================

# ---------- 端口（固定值，无需修改） ----------
# 前端 HTTP 端口
FRONTEND_PORT=3001
# 后端 API 端口（host 网络模式）
BACKEND_PORT=45001
# 数据库端口（宿主机映射）
DB_PORT=45000

# ---------- HTTPS（可配置） ----------
# HTTPS 端口（默认 443，如被占用改为 8443 等）
SSL_PORT=443
# 域名（配置 SSL 时必填）
DOMAIN=

# ---------- 数据库 ----------
DB_NAME=subforge
DB_USER=subforge
DB_PASSWORD=change-me-db-password
DB_SSL_MODE=disable

# ---------- JWT 认证 ----------
JWT_SECRET=change-me-jwt-secret-at-least-32-chars
JWT_EXPIRY=24h

# ---------- 管理员 ----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ---------- 其他 ----------
CORS_ORIGINS=
ADMIN_IP_WHITELIST=
GIN_MODE=debug
