# SubForge Configuration
# Copy this file to .env and modify as needed

# Server port
PORT=8080

# Database
DB_NAME=subforge
DB_USER=subforge
DB_PASSWORD=change-me-db-password
DB_SSL_MODE=disable  # disable for Docker internal, require for external DB

# JWT
JWT_SECRET=change-me-jwt-secret-at-least-32-chars
JWT_EXPIRY=24h

# Default admin password (first run only)
ADMIN_PASSWORD=admin123

# CORS (comma-separated origins, empty = same-origin only)
# Example: CORS_ORIGINS=https://subforge.example.com,http://localhost:3000
CORS_ORIGINS=

# Admin IP whitelist (comma-separated IPs, empty = no restriction)
# Example: ADMIN_IP_WHITELIST=192.168.1.100,10.0.0.0/8
ADMIN_IP_WHITELIST=

# Gin mode (debug/release)
GIN_MODE=debug
