# ========================================
# SubForge 环境配置示例
# 复制此文件为 .env 并按需修改
# ========================================

# ---------- 端口配置 ----------
# 前端 HTTP 端口（nginx 监听）
FRONTEND_PORT=3001
# 后端 API 端口（Python 直接监听，host 网络模式）
BACKEND_PORT=3002
# 数据库端口（宿主机映射）
DB_PORT=45000
# HTTPS 端口（需要 SSL 证书时生效）
SSL_PORT=3003

# ---------- 域名/SSL ----------
# 域名（配置 SSL 时必填）
DOMAIN=

# ---------- 数据库 ----------
DB_NAME=subforge
DB_USER=subforge
DB_PASSWORD=change-me-db-password
DB_SSL_MODE=disable

# ---------- JWT 认证 ----------
JWT_SECRET=change-me-jwt-secret-at-least-32-chars
JWT_EXPIRY=24h

# ---------- 管理员 ----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ---------- 其他 ----------
CORS_ORIGINS=
ADMIN_IP_WHITELIST=
GIN_MODE=debug
