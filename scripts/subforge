#!/bin/bash
# SubForge CLI - 交互式管理工具

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

INSTALL_DIR="/opt/subforge"

cd "$INSTALL_DIR" 2>/dev/null || { echo -e "${RED}SubForge 未安装${NC}"; exit 1; }

show_menu() {
    echo ""
    echo -e "${CYAN}${BOLD}═══════════════════════════════════════${NC}"
    echo -e "${CYAN}${BOLD}  🚀 SubForge 管理${NC}"
    echo -e "${CYAN}${BOLD}═══════════════════════════════════════${NC}"
    echo ""
    echo -e "  ${BOLD}1)${NC} 查看状态"
    echo -e "  ${BOLD}2)${NC} 启动服务"
    echo -e "  ${BOLD}3)${NC} 停止服务"
    echo -e "  ${BOLD}4)${NC} 重启服务"
    echo -e "  ${BOLD}5)${NC} 查看日志 (实时)"
    echo -e "  ${BOLD}6)${NC} 查看后端日志"
    echo -e "  ${BOLD}7)${NC} 查看数据库日志"
    echo -e "  ${BOLD}8)${NC} 进入后端容器"
    echo -e "  ${BOLD}9)${NC} 进入数据库"
    echo -e "  ${BOLD}10)${NC} 备份数据库"
    echo -e "  ${BOLD}11)${NC} 恢复数据库"
    echo -e "  ${BOLD}12)${NC} 更新版本"
    echo -e "  ${BOLD}13)${NC} 查看版本"
    echo -e "  ${BOLD}0)${NC} 退出"
    echo ""
    echo -e "${CYAN}${BOLD}═══════════════════════════════════════${NC}"
}

show_status() {
    echo ""
    echo -e "${CYAN}${BOLD}服务状态:${NC}"
    docker compose ps
    echo ""
    echo -e "${CYAN}${BOLD}访问地址:${NC}"
    if [ -f .env ]; then
        PORT=$(grep -E '^FRONTEND_PORT=' .env | cut -d'=' -f2 | tr -d '[:space:]')
    fi
    PORT=${PORT:-3001}
    echo -e "  http://localhost:${PORT}"
    echo ""
}

backup_database() {
    echo ""
    info "备份数据库..."
    BACKUP_DIR="$INSTALL_DIR/backups"
    mkdir -p "$BACKUP_DIR"
    BACKUP_FILE="$BACKUP_DIR/subforge-$(date +%Y%m%d_%H%M%S).sql"

    if docker exec subforge-db pg_dump -U subforge subforge > "$BACKUP_FILE" 2>/dev/null; then
        BACKUP_SIZE=$(du -h "$BACKUP_FILE" | cut -f1)
        echo -e "${GREEN}[✓]${NC} 备份完成: $BACKUP_FILE ($BACKUP_SIZE)"
    else
        echo -e "${RED}[✗]${NC} 备份失败"
    fi
}

restore_database() {
    echo ""
    echo -e "${YELLOW}可用备份:${NC}"
    ls -la "$INSTALL_DIR/backups/"*.sql 2>/dev/null || { echo -e "${RED}没有找到备份文件${NC}"; return; }
    echo ""
    read -p "$(echo -e ${YELLOW}输入备份文件名: ${NC})" BACKUP_FILE

    if [ ! -f "$BACKUP_FILE" ]; then
        echo -e "${RED}文件不存在${NC}"
        return
    fi

    read -p "$(echo -e ${RED}⚠️  确认恢复? 这将覆盖当前数据 [y/N]: ${NC})" confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        docker exec -i subforge-db psql -U subforge subforge < "$BACKUP_FILE"
        echo -e "${GREEN}[✓]${NC} 恢复完成"
        docker compose restart backend
    fi
}

show_version() {
    echo ""
    echo -e "${CYAN}${BOLD}SubForge 版本信息:${NC}"
    echo -e "  版本:     ${BOLD}$(cat VERSION 2>/dev/null || echo 'unknown')${NC}"
    echo -e "  Git:      $(git rev-parse --short HEAD 2>/dev/null || echo 'unknown')"
    echo ""
    echo -e "${CYAN}${BOLD}Docker 镜像:${NC}"
    docker images | grep -E "subforge|REPOSITORY"
    echo ""
}

update_version() {
    echo ""
    echo -e "${YELLOW}⚠️  即将更新 SubForge${NC}"
    read -p "$(echo -e ${YELLOW}确认更新? [y/N]: ${NC})" confirm

    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        echo ""
        echo -e "${CYAN}[i]${NC} 备份数据库..."
        backup_database

        echo -e "${CYAN}[i]${NC} 拉取最新代码..."
        git fetch origin main
        git reset --hard origin/main

        echo -e "${CYAN}[i]${NC} 加载镜像..."
        docker load < images/subforge-backend.tar.gz 2>/dev/null || true
        docker load < images/subforge-frontend.tar.gz 2>/dev/null || true

        echo -e "${CYAN}[i]${NC} 重启服务..."
        docker compose down --remove-orphans
        docker compose up -d

        echo -e "${GREEN}[✓]${NC} 更新完成"
        show_status
    fi
}

info()  { echo -e "${CYAN}[i]${NC} $1"; }

while true; do
    show_menu
    read -p "$(echo -e ${BOLD}请选择 [0-13]: ${NC})" choice

    case $choice in
        1) show_status ;;
        2)
            echo ""
            docker compose up -d
            echo -e "${GREEN}[✓]${NC} 服务已启动"
            ;;
        3)
            echo ""
            docker compose down
            echo -e "${GREEN}[✓]${NC} 服务已停止"
            ;;
        4)
            echo ""
            docker compose restart
            echo -e "${GREEN}[✓]${NC} 服务已重启"
            ;;
        5)
            echo ""
            echo -e "${DIM}按 Ctrl+C 退出日志${NC}"
            docker compose logs -f
            ;;
        6)
            echo ""
            docker compose logs -f backend
            ;;
        7)
            echo ""
            docker compose logs -f db
            ;;
        8)
            echo ""
            docker exec -it subforge-backend /bin/sh
            ;;
        9)
            echo ""
            docker exec -it subforge-db psql -U subforge subforge
            ;;
        10) backup_database ;;
        11) restore_database ;;
        12) update_version ;;
        13) show_version ;;
        0|q|Q)
            echo ""
            echo -e "${GREEN}再见! 👋${NC}"
            exit 0
            ;;
        *)
            echo -e "${RED}无效选项${NC}"
            ;;
    esac

    echo ""
    read -p "$(echo -e ${DIM}按回车继续...${NC})" _
done
